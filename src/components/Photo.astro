---
/**
 * Site-wide photo wrapper around astro:assets <Image />.
 * Every photo is encoded to AVIF with a responsive srcset and lazy-loads
 * by default. The wrapper div fixes the layout slot's aspect ratio so
 * collages keep their composition regardless of the source photo's crop.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  /** CSS aspect-ratio of the layout slot (e.g. "4/3"), or "fill" to size from the parent box */
  ratio?: string;
  class?: string;
  /** srcset sizes hint; defaults to full-width on mobile, half on desktop */
  sizes?: string;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  ratio = '4/3',
  class: className = '',
  sizes = '(min-width: 1024px) 50vw, 100vw',
  loading = 'lazy',
} = Astro.props;
---

<div
  class:list={['group w-full overflow-hidden', ratio === 'fill' && 'h-full', className]}
  style={ratio === 'fill' ? undefined : `aspect-ratio: ${ratio};`}
>
  <Image
    src={src}
    alt={alt}
    format="avif"
    quality={60}
    widths={[640, 1024, 1600]}
    sizes={sizes}
    loading={loading}
    class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
  />
</div>

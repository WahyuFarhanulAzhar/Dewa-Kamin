---
import Photo from './Photo.astro';
import designerSofa from '../assets/photos/contact-designer-sofa.jpg';
---

<!-- PDF page 66: white->gray gradient, two icon columns, 2:3 photo right, thin rule lines -->
<section id="contact" class="to-fog bg-gradient-to-r from-white">
  <div class="mx-auto max-w-[1280px] px-4 pt-14 pb-16 sm:px-6 lg:px-8 lg:pt-12 lg:pb-20">
    <h2 class="font-display text-5xl uppercase sm:text-6xl lg:text-[80px] lg:leading-none" data-fade>
      CONTACT
    </h2>
    <p
      class="font-display text-accent mt-8 text-center text-2xl sm:text-3xl lg:ml-[16%] lg:text-left lg:text-[39px] lg:leading-none"
      data-fade
    >
      Dewa Kamin Interior Design
    </p>

    <hr class="border-hairline mt-5 border-t" />

    <div class="mt-10 grid grid-cols-1 items-start gap-12 lg:grid-cols-12 lg:gap-8">
      <div class="grid grid-cols-1 gap-x-8 gap-y-10 sm:grid-cols-2 lg:col-span-8 lg:gap-y-14 lg:pl-[4%]" data-fade-group>
        <!-- Left column: address / phone / email / website -->
        <div class="space-y-10 lg:space-y-14">
          <div class="flex gap-5">
            <svg class="text-umber mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"></path>
            </svg>
            <div>
              <h3 class="font-display text-base uppercase lg:text-[18px]">OFFICE ADDRESS</h3>
              <p class="font-sans mt-1.5 text-sm font-light lg:text-[16px] lg:leading-relaxed">
                121 Forest Heights Blvd,<br />Toronto Canada M2L 2K7
              </p>
            </div>
          </div>

          <div class="flex gap-5">
            <svg class="text-umber mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.6 10.8a15.9 15.9 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1z"></path>
            </svg>
            <div>
              <h3 class="font-display text-base uppercase lg:text-[18px]">PHONE</h3>
              <p class="font-sans mt-1.5 text-sm font-light lg:text-[16px]">
                <a href="tel:+14168208669" class="hover:underline">(416) 820-8669</a>
              </p>
            </div>
          </div>

          <div class="flex gap-5">
            <svg class="text-umber mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="1.5"></rect>
              <path d="m3.5 6 8.5 7 8.5-7"></path>
            </svg>
            <div>
              <h3 class="font-display text-base uppercase lg:text-[18px]">EMAIL</h3>
              <p class="font-sans mt-1.5 text-sm font-light lg:text-[16px] lg:leading-loose">
                <a href="mailto:info@dewakamin.com" class="hover:underline">info@dewakamin.com</a>
                <br />
                <a href="mailto:dewapatang@gmail.com" class="hover:underline">dewapatang@gmail.com</a>
              </p>
            </div>
          </div>

          <div class="flex gap-5">
            <svg class="text-umber mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="8.5"></circle>
              <path d="M3.5 12h17M12 3.5c2.5 2.3 3.8 5.2 3.8 8.5s-1.3 6.2-3.8 8.5c-2.5-2.3-3.8-5.2-3.8-8.5s1.3-6.2 3.8-8.5z"></path>
            </svg>
            <div>
              <h3 class="font-display text-base uppercase lg:text-[18px]">WEBSITE</h3>
              <p class="font-sans mt-1.5 text-sm font-light lg:text-[16px]">
                <a href="https://www.dewakamin.com" rel="noopener" class="hover:underline">www.dewakamin.com</a>
              </p>
            </div>
          </div>
        </div>

        <!-- Right column: instagram / linkedin -->
        <div class="space-y-10 lg:space-y-14">
          <div class="flex gap-5">
            <svg class="text-umber mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"></circle>
            </svg>
            <div>
              <h3 class="font-display text-base uppercase lg:text-[18px]">INSTAGRAM</h3>
              <p class="font-sans mt-1.5 text-sm font-light lg:text-[16px]">
                <a href="https://www.instagram.com/DewaKaminInteriorDesign" rel="noopener" class="hover:underline"
                  >@DewaKaminInteriorDesign</a
                >
              </p>
            </div>
          </div>

          <div class="flex gap-5">
            <svg class="text-umber mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.06A4.18 4.18 0 0 1 16.6 9c4 0 4.4 2.6 4.4 6v6h-4v-5.3c0-1.3 0-2.9-1.8-2.9s-2.2 1.4-2.2 2.8V21H9z"></path>
            </svg>
            <div>
              <h3 class="font-display text-base uppercase lg:text-[18px]">LINKEDIN</h3>
              <p class="font-sans mt-1.5 text-sm font-light lg:text-[16px]">
                <a href="https://www.linkedin.com/company/DewaKaminInteriorDesign" rel="noopener" class="hover:underline"
                  >linkedin.com/DewaKaminInteriorDesign</a
                >
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mx-auto w-full max-w-sm lg:col-span-4 lg:col-start-9 lg:max-w-none lg:pr-[2%]" data-fade>
        <Photo
          src={designerSofa}
          alt="Dewa Patang seated on a sofa with the city skyline behind"
          ratio="2/3"
          sizes="(min-width: 1024px) 29vw, 100vw"
        />
      </div>
    </div>

    <hr class="border-hairline mt-14 border-t" />
  </div>
</section>

---
import Photo from './Photo.astro';
import designerSofa from '../assets/photos/contact-designer-sofa.jpg';
---

<section id="contact" class="from-mist-light to-mist-dark bg-gradient-to-b">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-10 lg:py-24">
    <h2 class="font-display text-4xl tracking-wide uppercase sm:text-5xl lg:text-6xl" data-fade>CONTACT</h2>
    <p class="font-logo text-accent mt-6 text-center text-3xl tracking-[0.08em] uppercase sm:text-4xl" data-fade>
      Dewa Kamin Interior Design
    </p>

    <hr class="border-ink/20 mt-6 border-t" />

    <div class="mt-12 grid grid-cols-1 items-start gap-12 lg:grid-cols-12 lg:gap-14">
      <dl class="grid grid-cols-1 gap-x-10 gap-y-10 text-lg sm:grid-cols-2 lg:col-span-7" data-fade-group>
        <div class="flex gap-4">
          <svg class="mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"></path>
          </svg>
          <div>
            <dt class="font-display tracking-wide uppercase">OFFICE ADDRESS</dt>
            <dd class="mt-1">121 Forest Heights Blvd,<br />Toronto Canada M2L 2K7</dd>
          </div>
        </div>

        <div class="flex gap-4">
          <svg class="mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8a15.9 15.9 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1z"></path>
          </svg>
          <div>
            <dt class="font-display tracking-wide uppercase">PHONE</dt>
            <dd class="mt-1"><a href="tel:+14168208669" class="hover:underline">(416) 820-8669</a></dd>
          </div>
        </div>

        <div class="flex gap-4">
          <svg class="mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="1.5"></rect>
            <path d="m3.5 6 8.5 7 8.5-7"></path>
          </svg>
          <div>
            <dt class="font-display tracking-wide uppercase">EMAIL</dt>
            <dd class="mt-1">
              <a href="mailto:info@dewakamin.com" class="hover:underline">info@dewakamin.com</a>
              <br />
              <a href="mailto:dewapatang@gmail.com" class="hover:underline">dewapatang@gmail.com</a>
            </dd>
          </div>
        </div>

        <div class="flex gap-4">
          <svg class="mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"></circle>
          </svg>
          <div>
            <dt class="font-display tracking-wide uppercase">INSTAGRAM</dt>
            <dd class="mt-1">
              <a
                href="https://www.instagram.com/DewaKaminInteriorDesign"
                rel="noopener"
                class="hover:underline">@DewaKaminInteriorDesign</a
              >
            </dd>
          </div>
        </div>

        <div class="flex gap-4">
          <svg class="mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.06A4.18 4.18 0 0 1 16.6 9c4 0 4.4 2.6 4.4 6v6h-4v-5.3c0-1.3 0-2.9-1.8-2.9s-2.2 1.4-2.2 2.8V21H9z"></path>
          </svg>
          <div>
            <dt class="font-display tracking-wide uppercase">LINKEDIN</dt>
            <dd class="mt-1">
              <a
                href="https://www.linkedin.com/company/DewaKaminInteriorDesign"
                rel="noopener"
                class="hover:underline">linkedin.com/DewaKaminInteriorDesign</a
              >
            </dd>
          </div>
        </div>

        <div class="flex gap-4">
          <svg class="mt-1 h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="12" cy="12" r="8.5"></circle>
            <path d="M3.5 12h17M12 3.5c2.5 2.3 3.8 5.2 3.8 8.5s-1.3 6.2-3.8 8.5c-2.5-2.3-3.8-5.2-3.8-8.5s1.3-6.2 3.8-8.5z"></path>
          </svg>
          <div>
            <dt class="font-display tracking-wide uppercase">WEBSITE</dt>
            <dd class="mt-1">
              <a href="https://www.dewakamin.com" rel="noopener" class="hover:underline"
                >www.dewakamin.com</a
              >
            </dd>
          </div>
        </div>
      </dl>

      <div class="mx-auto w-full max-w-sm lg:col-span-4 lg:col-start-9" data-fade>
        <Photo
          src={designerSofa}
          alt="Dewa Patang seated on a sofa with the city skyline behind"
          ratio="3/4"
          sizes="(min-width: 1024px) 24rem, 100vw"
        />
      </div>
    </div>
  </div>
</section>

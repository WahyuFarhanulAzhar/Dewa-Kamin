---
/**
 * Projects overview — PDF page 56. The four photo strips are the exact
 * strip images from the PDF; heading and labels are positioned on the
 * same canvas.
 */
import Photo from './Photo.astro';
import type { ImageMetadata } from 'astro';
import layout from '../data/pdf-layout.json';

const photos = import.meta.glob<{ default: ImageMetadata }>('../assets/photos/pdf/*.jpg', {
  eager: true,
});
const page = (layout as Record<string, { aspect: number; images: any[] }>)['56'];

/* Label positions, size (22.1pt -> 2.157cqw) and letter-spacing come
   from the PDF's own text spans on page 56. */
const labels = [
  { text: 'TORONTO RESIDENCE', x: 3.2, y: 30.61, tracking: '0.025em' },
  { text: 'MODERN FARMHOUSE', x: 41.49, y: 51.82, tracking: '0.005em' },
  { text: 'RENOVATIONS', x: 3.68, y: 78.18, tracking: '0.029em' },
  { text: 'DOWNTOWN CORPORATE', x: 52.02, y: 96.56, tracking: '0.037em' },
];
const strips = page.images.map((im, i) => ({ ...im, label: labels[i] }));
---

<section class="bg-espresso text-bone" aria-label="Projects">
  <div class="mx-auto max-w-[1440px] px-4 py-6 sm:px-6 lg:px-10 lg:py-10">
  <!-- Mobile: stacked strips with labels -->
  <div class="flex flex-col gap-6 lg:hidden">
    <h2 class="font-display text-4xl uppercase sm:text-5xl" data-fade>PROJECTS</h2>
    {
      strips.map((im) => (
        <div data-fade>
          <div class="aspect-(--ar) relative w-full" style={`--ar: ${im.px[0]}/${im.px[1]};`}>
            <Photo src={photos[`../assets/photos/pdf/${im.file}`].default} alt={im.alt} ratio="fill" />
          </div>
          <p class="font-body mt-2 text-lg tracking-[0.04em] uppercase">{im.label.text}</p>
        </div>
      ))
    }
  </div>

  <!-- Desktop: PDF canvas -->
  <div class="@container relative hidden w-full lg:block" style={`aspect-ratio: ${page.aspect};`}>
    <h2
      class="font-display absolute top-[3.15%] left-[3.2%] text-[7.126cqw] leading-none tracking-[-0.027em] uppercase"
      data-fade
    >
      PROJECTS
    </h2>
    {
      strips.map((im) => (
        <>
          <div
            class="absolute"
            style={`left: ${im.x}%; top: ${im.y}%; width: ${im.w}%; height: ${im.h}%;`}
            data-fade
          >
            <Photo
              src={photos[`../assets/photos/pdf/${im.file}`].default}
              alt={im.alt}
              ratio="fill"
              sizes={`(min-width: 1024px) ${Math.round(im.w)}vw, 100vw`}
            />
          </div>
          <p
            class="font-body absolute z-10 text-[2.157cqw] leading-none uppercase"
            style={`left: ${im.label.x}%; top: ${im.label.y}%; letter-spacing: ${im.label.tracking};`}
            data-fade
          >
            {im.label.text}
          </p>
        </>
      ))
    }
  </div>
  </div>
</section>

---
/**
 * Projects overview — PDF page 56. The four photo strips are the exact
 * strip images from the PDF; heading and labels are positioned on the
 * same canvas.
 */
import Photo from './Photo.astro';
import type { ImageMetadata } from 'astro';
import layout from '../data/pdf-layout.json';

const photos = import.meta.glob<{ default: ImageMetadata }>('../assets/photos/pdf/*.jpg', {
  eager: true,
});
const page = (layout as Record<string, { aspect: number; images: any[] }>)['56'];
const labels = ['TORONTO RESIDENCE', 'MODERN FARMHOUSE', 'RENOVATIONS', 'DOWNTOWN CORPORATE'];
const strips = page.images.map((im, i) => ({ ...im, label: labels[i] }));
---

<section class="bg-espresso text-bone" aria-label="Projects">
  <!-- Mobile: stacked strips with labels -->
  <div class="flex flex-col gap-6 px-4 py-10 sm:px-6 lg:hidden">
    <h2 class="font-display text-4xl uppercase sm:text-5xl" data-fade>PROJECTS</h2>
    {
      strips.map((im) => (
        <div data-fade>
          <div class="aspect-(--ar) relative w-full" style={`--ar: ${im.px[0]}/${im.px[1]};`}>
            <Photo src={photos[`../assets/photos/pdf/${im.file}`].default} alt={im.alt} ratio="fill" />
          </div>
          <p class="font-body mt-2 text-lg tracking-[0.04em] uppercase">{im.label}</p>
        </div>
      ))
    }
  </div>

  <!-- Desktop: PDF canvas -->
  <div class="@container relative hidden w-full lg:block" style={`aspect-ratio: ${page.aspect};`}>
    <h2
      class="font-display absolute top-[3%] left-[4.4%] text-[7.1cqw] leading-none uppercase"
      data-fade
    >
      PROJECTS
    </h2>
    {
      strips.map((im) => (
        <>
          <div
            class="absolute"
            style={`left: ${im.x}%; top: ${im.y}%; width: ${im.w}%; height: ${im.h}%;`}
            data-fade
          >
            <Photo
              src={photos[`../assets/photos/pdf/${im.file}`].default}
              alt={im.alt}
              ratio="fill"
              sizes={`(min-width: 1024px) ${Math.round(im.w)}vw, 100vw`}
            />
          </div>
          <p
            class="font-body absolute z-10 text-[2.2cqw] tracking-[0.04em] uppercase"
            style={`left: ${im.x + 1}%; top: ${im.y + im.h + 1.2}%;`}
            data-fade
          >
            {im.label}
          </p>
        </>
      ))
    }
  </div>
</section>

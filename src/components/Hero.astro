---
import Photo from './Photo.astro';
import type { ImageMetadata } from 'astro';
import layout from '../data/pdf-layout.json';

const photos = import.meta.glob<{ default: ImageMetadata }>('../assets/photos/pdf/*.jpg', {
  eager: true,
});
const page = (layout as Record<string, { aspect: number; images: any[] }>)['3'];
const img = (n: number) => photos[`../assets/photos/pdf/${page.images[n].file}`].default;
---

<!--
  PDF page 3, full-bleed. On desktop the canvas keeps the PDF's 1024:550
  aspect but is capped so announcement bar + navbar + hero fit in 100svh.
-->
<section id="top" class="to-fog/60 bg-gradient-to-b from-white" aria-label="Introduction">
  <!-- Mobile / tablet: stacked -->
  <div class="flex flex-col gap-3 px-4 pt-6 pb-8 sm:px-6 lg:hidden" data-fade-group>
    <h1 class="font-hero text-accent text-center text-[26px] leading-[1.32] text-balance sm:text-3xl">
      Residential, commercial, hospitality, and retail interiors defined by craft, context, and
      lasting design intent
    </h1>
    {
      page.images.map((im) => (
        <div class="aspect-(--ar) relative w-full" style={`--ar: ${im.px[0]}/${im.px[1]};`}>
          <Photo
            src={photos[`../assets/photos/pdf/${im.file}`].default}
            alt={im.alt}
            ratio="fill"
            loading="eager"
          />
        </div>
      ))
    }
  </div>

  <!-- Desktop: PDF canvas, height-capped to the viewport -->
  <div class="hidden lg:flex lg:h-[calc(100svh-9rem)] lg:justify-center">
    <div
      class="@container relative h-full max-w-full"
      style={`aspect-ratio: ${page.aspect};`}
      data-fade-group
    >
      {
        page.images.map((im) => (
          <div
            class="absolute"
            style={`left: ${im.x}%; top: ${im.y}%; width: ${im.w}%; height: ${im.h}%; z-index: ${im.z};`}
          >
            <Photo
              src={photos[`../assets/photos/pdf/${im.file}`].default}
              alt={im.alt}
              ratio="fill"
              sizes={`(min-width: 1024px) ${Math.round(im.w)}vw, 100vw`}
              loading="eager"
            />
          </div>
        ))
      }
      <h1
        class="font-hero text-accent absolute top-[3.5%] left-[5.5%] z-10 w-[39%] text-center text-[3.45cqw] leading-[1.32]"
      >
        Residential, commercial, hospitality, and retail interiors defined by craft, context, and
        lasting design intent
      </h1>
    </div>
  </div>
</section>

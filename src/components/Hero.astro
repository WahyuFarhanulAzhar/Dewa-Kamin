---
import Photo from './Photo.astro';
import cabinet from '../assets/photos/pdf/p03-1.jpg';
import fireplace from '../assets/photos/pdf/p03-2.jpg';
import exterior from '../assets/photos/pdf/p03-3.jpg';

/* Boxes and text metrics measured from PDF page 3 (1024x550 canvas). */
const images = [
  { src: cabinet, alt: 'Staircase landing and dark wood display cabinet beside the dining table', box: 'lg:left-[32.4%] lg:top-0 lg:w-[43.2%] lg:h-[80%]', z: 1, sizes: '(min-width: 1024px) 44vw, 100vw' },
  { src: fireplace, alt: 'Marble fireplace with abstract artwork, wall sconces and a pendant light', box: 'lg:left-[76.9%] lg:top-[28%] lg:w-[23.1%] lg:h-[70%]', z: 2, sizes: '(min-width: 1024px) 24vw, 100vw' },
  { src: exterior, alt: 'Stone home exterior at dusk with a car parked in the driveway', box: 'lg:left-0 lg:top-[43.4%] lg:w-[45.6%] lg:h-[56.6%]', z: 3, sizes: '(min-width: 1024px) 46vw, 100vw' },
];
---

<!--
  PDF page 3. One responsive node set: stacked column on mobile, absolute
  canvas (aspect 1024:550, height-capped to 100svh with the header) at lg.
-->
<section id="top" aria-label="Introduction">
  <h1 class="sr-only">
    Residential, commercial, hospitality, and retail interiors defined by craft, context, and
    lasting design intent
  </h1>

  <div class="mx-auto max-w-[1440px] lg:flex lg:h-[calc(100svh-9rem)] lg:justify-center lg:px-10">
    <div
      class="@container relative flex flex-col gap-3 px-4 pt-6 pb-8 sm:px-6 lg:block lg:aspect-[1024/550] lg:h-full lg:max-w-full lg:p-0"
      data-fade-group
    >
      <p
        aria-hidden="true"
        class="font-hero text-accent order-first text-center text-[26px] leading-[1.08] text-balance sm:text-3xl lg:absolute lg:top-[1.8%] lg:left-0 lg:z-10 lg:order-none lg:w-[46.4%] lg:text-[3.478cqw] lg:leading-[0.99] lg:tracking-normal lg:text-wrap"
      >
        Residential, commercial, hospitality, and retail interiors defined by craft, context, and
        lasting design intent
      </p>
      {
        images.map((im) => (
          <div
            class:list={['aspect-(--ar) relative w-full lg:absolute lg:aspect-auto', im.box]}
            style={`--ar: ${im.src.width}/${im.src.height}; z-index: ${im.z};`}
          >
            <Photo src={im.src} alt={im.alt} ratio="fill" sizes={im.sizes} loading="eager" />
          </div>
        ))
      }
    </div>
  </div>
</section>

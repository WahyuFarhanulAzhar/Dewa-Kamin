---
import Photo from './Photo.astro';
import cabinet from '../assets/photos/pdf/p03-1.jpg';
import fireplace from '../assets/photos/pdf/p03-2.jpg';
import exterior from '../assets/photos/pdf/p03-3.jpg';

const ALT = {
  cabinet: 'Staircase landing and dark wood display cabinet beside the dining table',
  fireplace: 'Marble fireplace with abstract artwork, wall sconces and a pendant light',
  exterior: 'Stone home exterior at dusk with a car parked in the driveway',
};
---

<!--
  PDF page 3, full-bleed. Boxes and text metrics measured from the PDF:
  headline block x0-46.4% centered, 35.63pt (3.478cqw), line-height 0.99;
  cabinet photo x32.4-75.6 y0-80; fireplace x76.9-100 y28-98; exterior
  x0-45.6 y43.4-100. Canvas capped so header + hero fit in 100svh.
-->
<section id="top" class="to-fog/60 bg-gradient-to-b from-white" aria-label="Introduction">
  <!-- Mobile / tablet: stacked -->
  <div class="flex flex-col gap-3 px-4 pt-6 pb-8 sm:px-6 lg:hidden" data-fade-group>
    <h1 class="font-hero text-accent text-center text-[26px] leading-[1.08] text-balance sm:text-3xl">
      Residential, commercial, hospitality, and retail interiors defined by craft, context, and
      lasting design intent
    </h1>
    <Photo src={cabinet} alt={ALT.cabinet} ratio="1/1" loading="eager" />
    <Photo src={fireplace} alt={ALT.fireplace} ratio="3/4" loading="eager" />
    <Photo src={exterior} alt={ALT.exterior} ratio="3/2" loading="eager" />
  </div>

  <!-- Desktop: PDF canvas, height-capped to the viewport -->
  <div class="hidden lg:flex lg:h-[calc(100svh-9rem)] lg:justify-center">
    <div class="@container relative h-full max-w-full" style="aspect-ratio: 1024/550;" data-fade-group>
      <div class="absolute" style="left: 32.4%; top: 0; width: 43.2%; height: 80%;">
        <Photo src={cabinet} alt={ALT.cabinet} ratio="fill" sizes="44vw" loading="eager" />
      </div>
      <div class="absolute" style="left: 76.9%; top: 28%; width: 23.1%; height: 70%; z-index: 2;">
        <Photo src={fireplace} alt={ALT.fireplace} ratio="fill" sizes="24vw" loading="eager" />
      </div>
      <div class="absolute" style="left: 0; bottom: 0; width: 45.6%; height: 56.6%; z-index: 3;">
        <Photo src={exterior} alt={ALT.exterior} ratio="fill" sizes="46vw" loading="eager" />
      </div>
      <h1
        class="font-hero text-accent absolute top-[1.8%] left-0 z-10 w-[46.4%] text-center text-[3.478cqw] leading-[0.99] tracking-normal"
      >
        Residential, commercial, hospitality, and retail interiors defined by craft, context, and
        lasting design intent
      </h1>
    </div>
  </div>
</section>

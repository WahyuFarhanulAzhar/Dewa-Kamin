---
/**
 * Hero — full-bleed background video (client feedback 2026-07-14,
 * replacing the PDF page-3 collage) with the headline overlaid.
 * Reuses the compressed studio video; faststart lets it stream
 * progressively (~0.8 Mbps), and the poster paints immediately.
 * Sized so announcement bar + navbar + hero fit in 100svh.
 */
---

<section id="top" aria-label="Introduction">
  <h1 class="sr-only">
    Residential, commercial, hospitality, and retail interiors defined by craft, context, and
    lasting design intent
  </h1>

  <div class="relative h-[calc(100svh-7.2rem)] w-full overflow-hidden lg:h-[calc(100svh-9rem)]">
    <video
      class="absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/video/dewa-interior-design-poster.jpg"
      aria-hidden="true"
      tabindex="-1"
    >
      <source src="/video/dewa-interior-design.mp4" type="video/mp4" />
    </video>

    <!-- Legibility scrim: dark wash fading out to the right -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/30 to-transparent" aria-hidden="true"></div>

    <div class="relative z-10 flex h-full items-center">
      <p
        aria-hidden="true"
        class="font-hero w-full px-6 text-left text-white text-[clamp(26px,3.478vw,54px)] leading-[1.15] text-balance sm:px-10 lg:w-[48%] lg:px-0 lg:pl-[3%] lg:leading-[0.99]"
        data-fade
      >
        Residential, commercial, hospitality, and retail interiors defined by craft, context, and
        lasting design intent
      </p>
    </div>
  </div>
</section>

<script>
  // Respect prefers-reduced-motion: show the poster, don't autoplay
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const video = document.querySelector<HTMLVideoElement>('#top video');
    if (video) {
      video.removeAttribute('autoplay');
      video.pause();
    }
  }
</script>

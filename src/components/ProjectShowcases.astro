---
/**
 * Project showcase pages from the PDF (57-65), rendered 1:1.
 * Titles overlay the collages exactly where the design places them.
 */
import CollagePage from './CollagePage.astro';

interface Block {
  page: number;
  bg: string;
  title?: { text: string; class: string };
  label: string;
}

/* Title positions, sizes and letter-spacing measured from the PDF text
   spans (size/1024 -> cqw; tracking solved so the rendered width matches
   the PDF's span width). */
const blocks: Block[] = [
  {
    page: 57,
    bg: 'bg-cocoa',
    title: {
      text: 'MODERN FARMHOUSE',
      class: 'lg:left-[40.1%] lg:top-[5.5%] lg:text-[5.08cqw] lg:tracking-[0.027em]',
    },
    label: 'Modern Farmhouse project',
  },
  { page: 58, bg: 'bg-cocoa', label: 'Modern Farmhouse project' },
  { page: 59, bg: 'bg-cocoa', label: 'Modern Farmhouse project' },
  { page: 60, bg: 'bg-cocoa', label: 'Modern Farmhouse project' },
  { page: 61, bg: 'bg-cocoa', label: 'Modern Farmhouse project' },
  {
    page: 62,
    bg: 'bg-taupe',
    title: {
      text: 'RENOVATIONS',
      class: 'lg:left-[58.5%] lg:top-[1.3%] lg:text-[5.27cqw] lg:tracking-[0.029em]',
    },
    label: 'Renovations project',
  },
  { page: 63, bg: 'bg-cocoa', label: 'Renovations project' },
  {
    page: 64,
    bg: 'bg-cocoa',
    title: {
      text: 'DOWNTOWN CORPORATE',
      class: 'lg:left-[38.8%] lg:top-[6%] lg:text-[4.78cqw] lg:tracking-[0.054em]',
    },
    label: 'Downtown Corporate project',
  },
  {
    page: 65,
    bg: 'bg-cocoa',
    title: {
      text: 'DOWNTOWN CORPORATE',
      class: 'lg:left-[40.8%] lg:top-[4.4%] lg:text-[4.59cqw] lg:tracking-[0.054em]',
    },
    label: 'Downtown Corporate project',
  },
];
---

<div aria-label="Project showcases">
  {
    blocks.map((block) => (
      <section class:list={[block.bg]} aria-label={block.label}>
        <div class="@container mx-auto max-w-[1440px] px-4 py-4 sm:px-6 lg:px-10 lg:py-6">
        <CollagePage page={block.page}>
          {block.title && (
            <h3
              class:list={[
                'font-display text-bone order-first z-20 pb-1 text-3xl uppercase sm:text-4xl lg:order-none lg:absolute lg:pb-0 lg:leading-none',
                block.title.class,
              ]}
              data-fade
            >
              {block.title.text}
            </h3>
          )}
        </CollagePage>
        </div>
      </section>
    ))
  }
</div>

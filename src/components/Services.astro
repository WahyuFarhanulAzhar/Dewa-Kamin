---
import Photo from './Photo.astro';
import designer from '../assets/photos/services-designer.jpg';

const services = [
  {
    title: 'RESIDENTIAL INTERIOR DESIGN',
    items: ['Interior Master Planning', 'Renovations', 'Furniture Design, Styling & Installations'],
  },
  {
    title: 'COMMERCIAL DESIGN',
    items: [
      'Commercial Interiors',
      'Lighting Design',
      'Retail Design',
      'Corporate Spaces',
      'Hospitality & Hotels',
    ],
  },
  {
    title: 'ARCHITECTURAL & BUILD',
    items: ['Architectural Drawings', 'New Build Construction', 'Exterior Design & Landscaping'],
  },
];
---

<!-- PDF page 53: white -> dark umber diagonal gradient, CMU Serif blocks, 2:3 photo right -->
<section id="services" class="to-umber via-fog bg-gradient-to-br from-white">
  <div class="mx-auto max-w-[1280px] px-4 py-16 sm:px-6 lg:px-12 lg:py-14">
    <h2 class="font-display text-6xl lowercase sm:text-7xl lg:text-[100px] lg:leading-none" data-fade>
      services
    </h2>

    <div class="mt-12 grid grid-cols-1 items-start gap-12 lg:mt-16 lg:grid-cols-12 lg:gap-10">
      <div class="font-services space-y-11 lg:col-span-6 lg:pl-[7%]" data-fade-group>
        {
          services.map((service) => (
            <div>
              <h3 class="text-2xl uppercase sm:text-[28px] lg:text-[31px] lg:leading-tight lg:whitespace-nowrap">
                {service.title}
              </h3>
              <ul class="mt-1.5 text-xl leading-[1.3] lg:text-[24px]">
                {service.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <div class="mx-auto w-full max-w-md lg:col-span-5 lg:col-start-8 lg:-mt-6 lg:max-w-none lg:pr-[7%]" data-fade>
        <Photo
          src={designer}
          alt="Dewa Patang reviewing material samples and design books at her desk"
          ratio="2/3"
          sizes="(min-width: 1024px) 33vw, 100vw"
        />
      </div>
    </div>
  </div>
</section>

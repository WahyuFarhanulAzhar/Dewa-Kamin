---
const links = [
  { href: '#about', label: 'ABOUT' },
  { href: '#services', label: 'SERVICES' },
  { href: '#portfolio', label: 'PORTFOLIO' },
  { href: '#contact', label: 'CONTACT' },
];
---

<header class="sticky top-0 z-50 bg-charcoal text-white shadow-md">
  <nav
    class="mx-auto flex max-w-[1280px] items-center justify-between gap-6 px-4 py-3 sm:px-6 lg:px-14 lg:py-3"
    aria-label="Main navigation"
  >
    <a href="#top" class="font-display text-center text-[22px] leading-[1.12] sm:text-[26px] lg:text-[32px]">
      <span class="block">DEWA KAMIN</span>
      <span class="block">INTERIOR DESIGN</span>
    </a>

    <button
      id="menu-toggle"
      type="button"
      class="p-2 md:hidden"
      aria-expanded="false"
      aria-controls="site-menu"
      aria-label="Toggle menu"
    >
      <svg
        class="h-7 w-7"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path stroke-linecap="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
      </svg>
    </button>

    <ul
      id="site-menu"
      class="absolute top-full right-0 left-0 hidden flex-col gap-1 bg-charcoal px-6 pt-2 pb-6 md:static md:flex md:flex-row md:items-center md:gap-8 md:bg-transparent md:p-0 lg:gap-14"
    >
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-body link-underline block py-2 text-base tracking-[0.04em] md:py-0 lg:text-[20px]"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('site-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  // Close the mobile menu after navigating to a section
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (toggle && window.getComputedStyle(toggle).display !== 'none') {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>

---
/**
 * Temporary stand-in for a real photo. Sized by aspect ratio so the
 * collage structure is visible before final assets arrive.
 * When real images land in src/assets/, replace each Placeholder with
 * <Image /> / <Picture /> from astro:assets (see CLAUDE.md rules).
 */
interface Props {
  label: string;
  /** CSS aspect-ratio, e.g. "4/3", "2/3", "16/9" */
  ratio?: string;
  /** "light" for light sections, "dark" for charcoal sections */
  variant?: 'light' | 'dark';
  class?: string;
}

const { label, ratio = '4/3', variant = 'light', class: className = '' } = Astro.props;
---

<div
  class:list={[
    'flex w-full items-center justify-center overflow-hidden border border-dashed p-2',
    variant === 'light'
      ? 'border-ink/30 bg-ink/10 text-ink/60'
      : 'border-white/25 bg-white/10 text-white/55',
    className,
  ]}
  style={`aspect-ratio: ${ratio};`}
  role="img"
  aria-label={`Image placeholder: ${label}`}
>
  <span class="text-center text-[0.65rem] leading-snug tracking-[0.2em] uppercase sm:text-xs">
    {label}
  </span>
</div>

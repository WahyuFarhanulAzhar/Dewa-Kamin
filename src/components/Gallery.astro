---
/**
 * Portfolio gallery — PDF pages 5-51 rendered 1:1 via CollagePage.
 * Thin dividers mark the original page boundaries, as in the design.
 */
import CollagePage from './CollagePage.astro';

const pages = Array.from({ length: 47 }, (_, i) => i + 5); // 5..51
---

<section id="portfolio" class="bg-espresso" aria-label="Portfolio gallery">
  <h2 class="sr-only">Portfolio</h2>
  {
    pages.map((page, i) => (
      <>
        {i > 0 && <hr class="mx-auto max-w-[1280px] border-t border-white/15" />}
        <CollagePage page={page} class="lg:py-0" />
      </>
    ))
  }
</section>

---
import Placeholder from './Placeholder.astro';
---

<section id="portfolio" class="bg-charcoal" aria-label="Portfolio gallery">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <h2 class="sr-only">Portfolio</h2>

    <!-- Home exteriors: two overlapping shots + person at the entrance -->
    <div class="grid grid-cols-1 gap-6 py-12 sm:py-16 lg:grid-cols-12 lg:gap-0">
      <div class="lg:col-span-5 lg:col-start-1 lg:row-start-1">
        <Placeholder label="Home exterior, dusk sky" ratio="4/3" variant="dark" />
      </div>
      <div class="lg:col-span-5 lg:col-start-2 lg:row-start-1 lg:mt-64 lg:ml-10">
        <Placeholder label="Home exterior, garden & front entry" ratio="16/10" variant="dark" />
      </div>
      <div class="lg:col-span-5 lg:col-start-8 lg:row-start-1">
        <Placeholder label="Person on entrance steps, iron railing" ratio="1/1" variant="dark" />
      </div>
    </div>

    <hr class="border-t border-white/20" />

    <!-- Full-width exterior -->
    <div class="py-12 sm:py-16">
      <div class="mx-auto lg:max-w-4xl">
        <Placeholder label="Home exterior with driveway & car" ratio="16/10" variant="dark" />
      </div>
    </div>

    <hr class="border-t border-white/20" />

    <!-- Grand entrance + person collage -->
    <div class="py-12 sm:py-16">
      <div class="mx-auto lg:max-w-3xl">
        <Placeholder label="Front entrance, stone steps at dusk" ratio="3/2" variant="dark" />
      </div>
      <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-0">
        <div class="lg:col-span-4 lg:col-start-1 lg:mt-10">
          <Placeholder label="Person on balcony overlooking street" ratio="3/4" variant="dark" />
        </div>
        <div class="lg:col-span-4 lg:col-start-5 lg:z-10 lg:-mx-2">
          <Placeholder label="Person at front door, planters" ratio="2/3" variant="dark" />
        </div>
        <div class="lg:col-span-4 lg:col-start-9 lg:mt-16">
          <Placeholder label="Person on garden terrace steps" ratio="3/4" variant="dark" />
        </div>
      </div>
    </div>

    <hr class="border-t border-white/20" />

    <!-- Interior living rooms & office -->
    <div class="py-12 sm:py-16">
      <div class="mx-auto lg:max-w-4xl">
        <Placeholder label="Home office with staircase & persian rug" ratio="3/2" variant="dark" />
      </div>
      <div class="mx-auto mt-10 lg:max-w-4xl">
        <Placeholder label="Desk by sheer curtains, home office" ratio="4/3" variant="dark" />
      </div>
      <div class="mx-auto mt-10 lg:max-w-4xl">
        <Placeholder label="Foyer, marble floor & round mirror" ratio="3/2" variant="dark" />
      </div>
      <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-0">
        <div class="lg:col-span-8 lg:col-start-1 lg:row-start-1">
          <Placeholder label="Living room, herringbone floor" ratio="4/3" variant="dark" />
        </div>
        <div class="lg:col-span-4 lg:col-start-8 lg:row-start-1 lg:z-10 lg:mt-24">
          <Placeholder label="Fireplace detail with pendant light" ratio="3/4" variant="dark" />
        </div>
      </div>
      <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-0">
        <div class="lg:col-span-5 lg:col-start-1 lg:row-start-1 lg:z-10">
          <Placeholder label="Built-in shelving detail" ratio="4/3" variant="dark" />
        </div>
        <div class="lg:col-span-8 lg:col-start-4 lg:row-start-1 lg:mt-16">
          <Placeholder label="Family room with media wall" ratio="3/2" variant="dark" />
        </div>
      </div>
    </div>

    <hr class="border-t border-white/20" />

    <!-- Staircase & dining -->
    <div class="py-12 sm:py-16">
      <div class="mx-auto lg:max-w-4xl">
        <Placeholder label="Sculptural staircase, iron balusters" ratio="3/2" variant="dark" />
      </div>
      <div class="mx-auto mt-10 lg:max-w-4xl">
        <Placeholder label="Dining room & glass display cabinet" ratio="3/2" variant="dark" />
      </div>
    </div>

    <hr class="border-t border-white/20" />

    <!-- Kitchens -->
    <div class="py-12 sm:py-16">
      <div class="mx-auto lg:max-w-4xl">
        <Placeholder label="Kitchen with island & pendant lights" ratio="3/2" variant="dark" />
      </div>
      <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-2">
        <Placeholder label="Glass cabinet doors detail" ratio="1/1" variant="dark" />
        <Placeholder label="Stone countertop & backsplash detail" ratio="1/1" variant="dark" />
      </div>
      <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-0">
        <div class="lg:col-span-5 lg:col-start-1 lg:row-start-1 lg:z-10">
          <Placeholder label="Stainless range hood detail" ratio="1/1" variant="dark" />
        </div>
        <div class="lg:col-span-6 lg:col-start-5 lg:row-start-1 lg:mt-20">
          <Placeholder label="Island sink & granite counter" ratio="4/3" variant="dark" />
        </div>
      </div>
      <div class="mx-auto mt-10 lg:max-w-4xl">
        <Placeholder label="Range & dark marble backsplash" ratio="3/2" variant="dark" />
      </div>
      <div class="mx-auto mt-10 lg:max-w-4xl">
        <Placeholder label="Kitchen island, wood cabinetry" ratio="16/10" variant="dark" />
      </div>
    </div>
  </div>
</section>

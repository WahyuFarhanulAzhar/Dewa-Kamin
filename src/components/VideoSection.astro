<!--
  Self-hosted studio video (compressed 720p H.264 from
  "DEWA INTERIOR DESIGN VIDEO-FINAL_Rev8.mp4"). preload="none" + poster
  keeps it off the critical path: nothing downloads until the visitor
  presses play.
-->
<section class="bg-rust" aria-label="Studio video">
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 sm:py-12">
    <video
      class="aspect-video w-full"
      controls
      preload="none"
      poster="/video/dewa-interior-design-poster.jpg"
      title="DEWA INTERIOR DESIGN VIDEO"
      data-fade
    >
      <source src="/video/dewa-interior-design.mp4" type="video/mp4" />
      Your browser does not support the video tag.
    </video>
  </div>
</section>
